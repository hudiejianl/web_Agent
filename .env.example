APP_NAME=Admission Research Agent
APP_ENV=development
DATABASE_PATH=data/runtime/admission_agent.sqlite3
CHROMA_PATH=data/runtime/chroma
CHROMA_COLLECTION=tutors
ANONYMIZED_TELEMETRY=False
LOG_LEVEL=INFO
ENABLE_BROWSER_RESEARCH=true
ENABLE_RAG_EVAL=true
AUTO_SEED_DATA=true
MAX_BROWSER_SEARCH_PAGES=2
MAX_BROWSER_CANDIDATES=10
MAX_BROWSER_INGEST=3
MAX_BROWSER_NAVIGATION_PAGES=8
EMBEDDING_MODEL=hashing
LLM_PROVIDER=none
LLM_MODEL=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_TIMEOUT_SECONDS=45
REQUEST_TIMEOUT_SECONDS=15
MAX_CONTEXT_MESSAGES=8
SUMMARY_TRIGGER_MESSAGES=10
